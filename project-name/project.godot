; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Template"
config/version="0.1.0"
run/main_scene="uid://ccxuyq6o8k8ca"
config/auto_accept_quit=false
config/features=PackedStringArray("4.7", "Forward Plus")
boot_splash/use_filter=false
boot_splash/image="uid://ro85vxlog3m8"
config/icon="uid://d3mmiy4avnipm"
boot_splash/minimum_display_time=1000

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=2000
window/size/window_height_override=1200
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/stretch/scale_mode="integer"

[file_customization]

folder_colors={
"res://src/debug/": "yellow"
}

